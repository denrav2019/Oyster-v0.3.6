print("=== Test 1: Direct strings ===")
$s1 = "Hello, World!"
print($s1)

print("=== Test 4: If/Else ===")
$x = 42
if($x > 100) { print("big") } else { print("small") }
if($x == 42) { print("the answer") }

print("=== Test 5: While loop ===")
$i = 0
while($i < 3) { print($i); inc $i }

print("=== Test 10: Functions ===")
fun add($x, $y) { return $x + $y }
print(add(10, 20))

print("=== All tests complete ===")
