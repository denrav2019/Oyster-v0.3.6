print("=== while: last, next, redo ===")
$i = 0
while($i < 5) {
    inc $i
    if($i == 2) { next }
    if($i == 4) { last }
    print($i)
}

print("=== for in: last, next, redo ===")
@arr = (10, 20, 30, 40)
for $x in @arr {
    if($x == 10) { next }
    if($x == 30) { last }
    print($x)
}

print("=== for C-style: last, next, redo ===")
for($i = 0; $i < 5; inc $i) {
    if($i == 0) { next }
    if($i == 3) { last }
    print($i)
}

print("done")
