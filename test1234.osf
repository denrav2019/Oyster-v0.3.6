# --- 1. –Я—А—П–Љ—Л–µ —Б—В—А–Њ–Ї–Є (–±–µ–Ј –њ—Г–ї–∞) ---
print("=== Test 1: Direct strings ===")
$s1 = "Hello, World!"
print($s1)
$s2 = "Hello, World!"   # —В–∞ –ґ–µ —Б—В—А–Њ–Ї–∞ вАФ –љ–µ –і—Г–±–ї–Є–Ї–∞—В –≤ .oce
print($s2)
print("")

# --- 2. –Ъ–Њ–љ—Б—В–∞–љ—В—Л ---
print("=== Test 2: Constants ===")
&PI = 3.14159
&NAME = "Oyster"
print(&PI)
print(&NAME)
print("")

# --- 3. –Р—А–Є—Д–Љ–µ—В–Є–Ї–∞ –Є —Б—А–∞–≤–љ–µ–љ–Є—П ---
print("=== Test 3: Arithmetic ===")
$a = 10
$b = 3
print($a + $b)
print($a - $b)
print($a * $b)
print($a / $b)
print($a % $b)
print($a == $b)
print($a != $b)
print($a > $b)
print($a < $b)
print("")

# --- 4. –£—Б–ї–Њ–≤–Є—П ---
print("=== Test 4: If/Else ===")
$x = 42
if($x > 100) {
    print("big")
} else {
    print("small")
}

if($x == 42) {
    print("the answer")
}
print("")

# --- 5. –¶–Є–Ї–ї—Л ---
print("=== Test 5: While loop ===")
$i = 0
while($i < 5) {
    print($i)
    inc($i)
}
print("")

# --- 6. –Ь–∞—Б—Б–Є–≤—Л ---
print("=== Test 6: Arrays ===")
@arr = (1, 2, 3, 4, 5)
print(len(@arr))
print(@arr[0])
print(@arr[4])
@arr[2] = 99
print(@arr[2])
print("")

# --- 7. –•–µ—И–Є ---
print("=== Test 7: Hashes ===")
%h = ("name" => "Oyster", "version" => "0.3.0")
print(%h["name"])
print(%h["version"])
print(haskeys(%h))
print(exists(%h, "name"))
print("")

# --- 8. –°—В—А–Њ–Ї–Њ–≤—Л–µ —Д—Г–љ–Ї—Ж–Є–Є ---
print("=== Test 8: String functions ===")
$str = "  Hello World  "
print(lc($str))
print(uc($str))
print(chomp("line\n"))
print(chop("Oyster!"))
print(len($str))
print(ord("A"))
print(chr(65))
print("")

# --- 9. –Ъ–Њ–љ–Ї–∞—В–µ–љ–∞—Ж–Є—П ---
print("=== Test 9: Concatenation ===")
$first = "Hello"
$last = "World"
print($first . " " . $last)
print("")

# --- 10. –§—Г–љ–Ї—Ж–Є–Є ---
print("=== Test 10: Functions ===")
fun add($x, $y) {
    return $x + $y
}
print(add(10, 20))

fun factorial($n) {
    if($n <= 1) {
        return 1
    }
    return $n * factorial($n - 1)
}
print(factorial(5))
print("")

# --- 11. –Ь–∞—В–µ–Љ–∞—В–Є–Ї–∞ ---
print("=== Test 11: Math ===")
print(abs(-42))
print(sign(-99))
print(int(3.14))
print(frac(3.14))
print(sqrt(16))
print(inv(5))
print("")

# --- 12. postfix{} (extended mode) ---
print("=== Test 12: postfix{} ===")
# –Ґ–Њ–ї—М–Ї–Њ –≤ —А–µ–ґ–Є–Љ–µ -e
# $a = 10
# $b = 20
# $c = postfix{ $a $b + 2.0 / }
