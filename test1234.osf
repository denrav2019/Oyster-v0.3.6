# --- 13. method() (extended mode) ---
print("=== Test 13: method() ===")
# –Ґ–Њ–ї—М–Ї–Њ –≤ —А–µ–ґ–Є–Љ–µ -e
fun greet($name) {
    print("Hello, " . $name)
}
fun square($x) {
    return $x * $x
}
# $result = 5.square()   # –≤—Л–Ј–Њ–≤ –Ї–∞–Ї –Љ–µ—В–Њ–і
# print($result)
print("method test skipped (use -e flag)")
print("")

# --- 14. –Ъ–Њ–Љ–±–Є–љ–Є—А–Њ–≤–∞–љ–љ—Л–є —В–µ—Б—В ---
print("=== Test 14: Combined ===")
@items = ("one", "two", "three")
%map = ()
$idx = 0
while($idx < len(@items)) {
    hadd(%map, $idx, @items[$idx])
    inc($idx)
}
print(%map[0])
print(%map[1])
print(%map[2])
print(exists(%map, 0))
print(haskeys(%map))
print("")

print("=== All basic tests complete ===")
