# Функции в начале файла
fun add($x, $y) { return $x + $y }
fun factorial($n) {
  if($n <= 1) { return 1 }
  return $n * factorial($n - 1)
}

print("=== Test 1: Direct strings ===")
$s1 = "Hello, World!"
print($s1)
print("")

print("=== Test 2: Constants ===")
&PI = 3.14159
print(&PI)
print("")

print("=== Test 3: Arithmetic ===")
$a = 10
$b = 3
print($a + $b)
print("")

print("=== Test 4: If/Else ===")
$x = 42
if($x > 100) { print("big") } else { print("small") }
print("")

print("=== Test 5: While loop ===")
$i = 0
while($i < 3) { print($i); inc $i }
print("")

print("=== Test 6: Arrays ===")
@arr = (1, 2, 3)
print(@arr[0])
print("")

print("=== Test 7: Hashes ===")
%h = ("name" => "Oyster")
print(%h["name"])
print("")

print("=== Test 8: String functions ===")
print(lc("HELLO"))
print(chop("Oyster!"))
print("")

print("=== Test 9: Concatenation ===")
print("Hello" + " " + "World")
print("")

print("=== Test 10: Functions ===")
print(add(10, 20))
print(factorial(5))
print("")

print("=== Test 11: Math ===")
print(abs(-42))
#print(sqrt(16))
print("")

print("=== Test 12: postfix ===")
$a = 10
$b = 20
$c = postfix{ $a $b + 2 / }
print($c)
print("")

print("=== Test 13: methods ===")
$x = -42
print($x.abs())
$s = "hello"
print($s.uc())
print("")

print("=== Test 14: Combined ===")
@items = ("one", "two", "three")
%map = ()
$idx = 0
while($idx < len(@items)) {
    hadd(%map, $idx, @items[$idx])
    inc $idx
}
$x = %map[0]
print($x)
print(haskeys(%map))
print("")

print("=== ALL TESTS PASSED ===")
